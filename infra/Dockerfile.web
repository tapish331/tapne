FROM node:22-slim AS lovable_builder

WORKDIR /frontend/lovable

COPY lovable/package.json ./package.json
COPY infra/lovable-build.package-lock.json ./package-lock.json
COPY infra/lovable-build.lock-metadata.json /frontend/infra/lovable-build.lock-metadata.json
RUN node -e "const fs = require('fs'); const crypto = require('crypto'); const meta = JSON.parse(fs.readFileSync('/frontend/infra/lovable-build.lock-metadata.json', 'utf8')); const actual = crypto.createHash('sha256').update(fs.readFileSync('/frontend/lovable/package.json')).digest('hex'); if (actual !== String(meta.package_json_sha256 || '').toLowerCase()) { console.error('Lovable build lock is stale. Refresh it with infra/refresh-lovable-build-lock.ps1 or infra/refresh-lovable-build-lock.sh before building.'); process.exit(1); }" \
    && npm ci

COPY lovable/ ./
COPY frontend_spa/ /frontend/frontend_spa/
RUN npx vite build --config /frontend/frontend_spa/vite.production.config.ts --outDir=/frontend/dist

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install --yes --no-install-recommends build-essential libpq-dev curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt
RUN python -m pip install --upgrade pip \
    && pip install -r /app/requirements.txt

# Match production hardening expectations by avoiding root runtime.
RUN useradd --create-home --uid 10001 appuser

COPY --chown=appuser:appuser . /app
COPY --from=lovable_builder --chown=appuser:appuser /frontend/dist /app/artifacts/lovable-production-dist

RUN chown appuser:appuser /app \
    && install -d -o appuser -g appuser /app/staticfiles /app/media

USER appuser

EXPOSE 8000

CMD ["sh", "-c", "if [ \"${COLLECTSTATIC_ON_BOOT:-true}\" = \"true\" ]; then python manage.py collectstatic --noinput; fi && exec gunicorn tapne.wsgi:application --bind 0.0.0.0:${PORT:-8000} --workers ${WEB_CONCURRENCY:-2} --timeout ${GUNICORN_TIMEOUT:-120} --access-logfile - --error-logfile -"]
